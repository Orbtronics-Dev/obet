# OBet — unified environment configuration
# Copy to .env and fill in real values before starting services.
# Lines prefixed NEXT_PUBLIC_ are also written to frontend/.env.local by `make init`.

# ── App ───────────────────────────────────────────────────────────────────────

APP_ENV=local
APP_NAME=OBet
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────

DB_PASSWORD=obet
DATABASE_URL=postgresql+psycopg2://obet:obet@localhost:5432/obet

# ── Auth ──────────────────────────────────────────────────────────────────────

JWT_SECRET=change_me_in_production_very_long_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OPay payment gateway ──────────────────────────────────────────────────────

OPAY_SECRET_KEY=opay_test_sk_XykBteGRvJ9bgqnPPLau5KtiVHrVm4Yp
OPAY_BASE_URL=https://staging.opay.orbtronics.co

# ── CORS / URLs ───────────────────────────────────────────────────────────────

FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# ── Business rules ────────────────────────────────────────────────────────────

PLATFORM_FEE_PCT=2

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# These are extracted into frontend/.env.local by `make init` / `just init`.

NEXT_PUBLIC_API_URL=http://localhost:8000
